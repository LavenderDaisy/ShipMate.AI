<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Standalone project: ignore any inherited (company) feeds and use nuget.org only. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
